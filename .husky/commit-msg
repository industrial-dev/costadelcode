#!/usr/bin/env sh
. "$(dirname "$0")/_/h"

commit_msg_file="$1"
first_line="$(sed -n '1p' "$commit_msg_file")"

pattern='^(:[a-z0-9_+-]+:[[:space:]]*)+(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)\([^[:space:]()]+\):[[:space:]].+'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  echo "ERROR: Invalid commit message."
  echo "Format: :gitmoji: type(scope): subject"
  echo "Example: :sparkles: feat(homepage): add hero copy"
  echo "Allowed types: feat, fix, chore, docs, style, refactor, perf, test, build, ci, revert"
  echo "Note: BREAKING CHANGE: in the body is allowed."
  exit 1
fi
