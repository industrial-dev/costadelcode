---
import BaseLayout from '../layouts/BaseLayout.astro';
import CommunityMosaicSection from '../components/CommunityMosaicSection.astro';
import JoinCta from '../components/JoinCta.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CommunityWhySection from '../components/CommunityWhySection.astro';
import CommunityOriginSection from '../components/CommunityOriginSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SetupCard from '../components/SetupCard.astro';
import { siteContent } from '../data/site-content';
import { pagePaths } from '../data/i18n';

const content = siteContent;
const { shared, pages } = content;
const community = pages.community;
---

<BaseLayout
  title={community.meta.title}
  description={community.meta.description}
  canonicalPath={pagePaths.community}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    cta={shared.primaryCta}
    menuLabel={shared.labels.menu}
    navigationLabel={shared.labels.navigation}
  />

  <main class="relative">
    <section class="section pt-12">
      <div class="shell mx-auto max-w-2xl">
        <p class="eyebrow">{community.hero.eyebrow}</p>
        <h1 class="title-xl mt-6">{community.hero.title}</h1>
        <p class="mt-6 text-xl leading-8 text-ink-800 md:text-2xl">
          {community.hero.intro}
        </p>
        <div class="body-copy mt-6 space-y-1">
          {community.hero.description.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <blockquote class="mt-8 border-l-2 border-code-green pl-5">
          <p
            class="font-display text-xl font-semibold tracking-[-0.03em] text-ink-950"
          >
            "{community.hero.founderIntro.note}"
          </p>
          <footer class="mt-3">
            <p class="eyebrow">
              {community.hero.founderIntro.name} · {
                community.hero.founderIntro.eyebrow
              }
            </p>
          </footer>
        </blockquote>
      </div>
    </section>

    <CommunityMosaicSection founderCard={community.founderCard} />

    <CommunityWhySection purpose={community.purpose} />

    {community.origin && <CommunityOriginSection origin={community.origin} />}

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={community.setups.eyebrow}
          title={community.setups.title}
          body={community.setups.intro}
        />
        <div class="grid gap-6 lg:grid-cols-2">
          {community.setups.items.map((setup) => <SetupCard setup={setup} />)}
        </div>
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
