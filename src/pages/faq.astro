---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaButton from '../components/CtaButton.astro';
import JoinCta from '../components/JoinCta.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteContent } from '../data/site-content';
import { pagePaths } from '../data/i18n';

const content = siteContent;
const { shared, pages } = content;
const faq = pages.faq;
---

<BaseLayout
  title={faq.meta.title}
  description={faq.meta.description}
  canonicalPath={pagePaths.faq}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    cta={shared.primaryCta}
    menuLabel={shared.labels.menu}
    navigationLabel={shared.labels.navigation}
  />

  <main class="relative">
    <section class="section pt-14">
      <div class="shell">
        <SectionHeading
          eyebrow={faq.hero.eyebrow}
          title={faq.hero.title}
          body={faq.hero.description}
          size="xl"
        />
        <p class="body-copy mt-5 max-w-3xl">{faq.hero.intro}</p>
      </div>
    </section>

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={faq.questions.eyebrow}
          title={faq.questions.title}
          body={faq.questions.intro}
        />
        <div class="grid gap-4 lg:grid-cols-2">
          {
            faq.questions.items.map((item) => (
              <article class="card p-6">
                <h3 class="font-display text-xl font-semibold tracking-[-0.03em] text-ink-950">
                  {item.question}
                </h3>
                <p class="body-copy mt-3">{item.answer}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="card p-8">
          <SectionHeading
            eyebrow={faq.contact.eyebrow}
            title={faq.contact.title}
            body={faq.contact.description}
          />
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            {faq.contact.ctaLinks.map((link) => <CtaButton link={link} />)}
          </div>
        </div>
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
