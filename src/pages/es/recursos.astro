---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JoinCta from '../../components/JoinCta.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../data/site-content';
import { pageAlternates, pagePaths } from '../../data/i18n';

const content = siteContent.es;
const { shared, pages } = content;
const resources = pages.resources;
---

<BaseLayout
  lang="es"
  title={resources.meta.title}
  description={resources.meta.description}
  canonicalPath={pagePaths.es.resources}
  alternates={pageAlternates('resources')}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    cta={shared.primaryCta}
    menuLabel={shared.labels.menu}
  />

  <main class="relative">
    <section class="section pt-14">
      <div class="shell">
        <SectionHeading
          eyebrow={resources.hero.eyebrow}
          title={resources.hero.title}
          body={resources.hero.description}
          size="xl"
        />
        <p class="body-copy mt-5 max-w-3xl">{resources.hero.intro}</p>
      </div>
    </section>

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={resources.categories.eyebrow}
          title={resources.categories.title}
          body={resources.categories.intro}
        />
        <div class="grid gap-6 lg:grid-cols-3">
          {
            resources.categories.items.map((category) => (
              <article class="card flex h-full flex-col gap-4 p-6">
                <div>
                  <h3 class="font-display text-2xl font-semibold tracking-[-0.03em] text-ink-950">
                    {category.title}
                  </h3>
                  <p class="body-copy mt-3">{category.description}</p>
                </div>
                <div class="mt-2 space-y-4">
                  {category.items.map((item) => (
                    <div class="rounded-2xl border border-[rgb(17_17_17/0.08)] bg-[rgb(255_255_255/0.7)] p-4">
                      <a
                        href={item.href}
                        class="text-sm font-semibold text-ink-950"
                      >
                        {item.name}
                      </a>
                      <p class="mt-2 text-sm text-[rgb(35_33_29/0.78)]">
                        {item.description}
                      </p>
                    </div>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="card p-8 lg:flex lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <p class="eyebrow">{resources.contribution.eyebrow}</p>
            <h2 class="title-lg mt-4">{resources.contribution.title}</h2>
            <p class="body-copy mt-4">{resources.contribution.description}</p>
          </div>
          <a
            href={resources.contribution.cta.href}
            class="button button-primary mt-6 w-fit lg:mt-0"
          >
            {resources.contribution.cta.label}
          </a>
        </div>
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
