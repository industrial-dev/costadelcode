---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import JoinCta from '../../components/JoinCta.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../data/site-content';
import { pageAlternates, pagePaths } from '../../data/i18n';

const content = siteContent.es;
const { shared, pages } = content;
const events = pages.events;
---

<BaseLayout
  lang="es"
  title={events.meta.title}
  description={events.meta.description}
  canonicalPath={pagePaths.es.events}
  alternates={pageAlternates('events')}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    cta={shared.primaryCta}
    menuLabel={shared.labels.menu}
  />

  <main class="relative">
    <section class="section pt-14">
      <div class="shell">
        <SectionHeading
          eyebrow={events.hero.eyebrow}
          title={events.hero.title}
          body={events.hero.description}
          size="xl"
        />
        <p class="body-copy mt-5 max-w-3xl">{events.hero.intro}</p>
      </div>
    </section>

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={events.upcoming.eyebrow}
          title={events.upcoming.title}
          body={events.upcoming.intro}
        />
        <div class="grid gap-6 lg:grid-cols-2">
          {
            events.upcoming.items.map((event) => (
              <EventCard event={event} labels={shared.labels} />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="card p-8 lg:flex lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <p class="eyebrow">{events.speakers.eyebrow}</p>
            <h2 class="title-lg mt-4">{events.speakers.title}</h2>
            <p class="body-copy mt-4">{events.speakers.description}</p>
          </div>
          <a
            href={events.speakers.cta.href}
            class="button button-secondary mt-6 w-fit lg:mt-0"
          >
            {events.speakers.cta.label}
          </a>
        </div>
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
