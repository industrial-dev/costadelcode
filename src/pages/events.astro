---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import JoinCta from '../components/JoinCta.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteContent } from '../data/site-content';
import { pagePaths } from '../data/i18n';

const content = siteContent;
const { shared, pages } = content;
const events = pages.events;
---

<BaseLayout
  title={events.meta.title}
  description={events.meta.description}
  canonicalPath={pagePaths.events}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    ctas={shared.ctaLinks}
    menuLabel={shared.labels.menu}
    navigationLabel={shared.labels.navigation}
  />

  <main class="relative">
    <section class="section relative overflow-hidden pt-14">
      <div
        class="hero-glow-warm pointer-events-none absolute -right-32 -top-10 h-80 w-80 rounded-full blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="shell">
        <div class="reveal max-w-3xl">
          <div class="flex items-center gap-3">
            <span class="eyebrow">{events.hero.eyebrow}</span>
            <span class="h-px w-10 bg-stone-300" aria-hidden="true"></span>
          </div>

          <h1 class="title-xl mt-4">
            {
              events.hero.titleHighlight
                ? events.hero.title
                    .replace(events.hero.titleHighlight, '')
                    .trimEnd()
                : events.hero.title
            }
            {
              events.hero.titleHighlight && (
                <mark
                  class="relative whitespace-nowrap bg-transparent text-ink-950"
                  style="background: linear-gradient(180deg, transparent 55%, rgb(243 212 88 / 0.55) 55%); -webkit-box-decoration-break: clone; box-decoration-break: clone;"
                >
                  {events.hero.titleHighlight}
                </mark>
              )
            }
          </h1>

          <p class="mt-5 text-xl leading-8 text-ink-800">
            {events.hero.description}
          </p>
          <p class="body-copy mt-4">{events.hero.intro}</p>
          <div class="mt-7 grid grid-cols-3 gap-3">
            {
              events.hero.formatAttributes.map((attr) => (
                <div class="rounded-xl border border-(--border-soft) bg-[rgb(255_255_255/0.65)] px-4 py-3 text-center">
                  <p class="font-display text-lg font-semibold tracking-tight text-ink-950">
                    {attr.value}
                  </p>
                  <p class="mt-0.5 text-xs uppercase tracking-[0.14em] text-stone-400">
                    {attr.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={events.upcoming.eyebrow}
          title={events.upcoming.title}
          body={events.upcoming.intro}
        />

        <div class="grid gap-6 lg:grid-cols-2">
          {
            events.upcoming.items.map((event) => (
              <EventCard event={event} labels={shared.labels} />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div
          class="relative overflow-hidden rounded-[1.6rem] bg-ink-950 px-8 py-10 md:px-12 md:py-14"
        >
          <div
            class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-accent-500/10 blur-3xl"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 right-0 h-0.75 bg-linear-to-r from-accent-500/80 to-accent-600/20"
            aria-hidden="true"
          >
          </div>
          <p class="eyebrow text-accent-500!">{events.speakers.eyebrow}</p>
          <h2 class="title-xl mt-4 text-white">{events.speakers.title}</h2>
          <p class="mt-5 max-w-xl text-lg leading-8 text-white/70">
            {events.speakers.description}
          </p>
          <div class="mt-8">
            <a
              href={events.speakers.cta.href}
              class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-6 py-3 font-semibold text-ink-950 transition-opacity hover:opacity-90"
            >
              {events.speakers.cta.label}
              <svg
                class="h-4 w-4"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
