---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import JoinCta from '../../components/JoinCta.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../data/site-content';
import { pageAlternates, pagePaths } from '../../data/i18n';

const content = siteContent.en;
const { shared, pages } = content;
const hero = pages.home.hero;
---

<BaseLayout
  lang="en"
  title={pages.home.meta.title}
  description={pages.home.meta.description}
  canonicalPath={pagePaths.en.home}
  alternates={pageAlternates('home')}
  showIntro={true}
>
  <SiteHeader
    brand={shared.brand}
    nav={shared.nav}
    cta={shared.primaryCta}
    menuLabel={shared.labels.menu}
  />

  <main class="relative">
    <section class="section relative overflow-hidden pt-14">
      <div
        class="hero-glow-warm pointer-events-none absolute -right-28 top-12 h-72 w-72 rounded-full blur-3xl animate-[float-slow_10s_ease-in-out_infinite]"
      >
      </div>
      <div
        class="hero-glow-soft pointer-events-none absolute -left-24 bottom-8 h-64 w-64 rounded-full blur-2xl"
      >
      </div>

      <div
        class="shell grid items-start gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]"
      >
        <div class="max-w-2xl">
          <p class="eyebrow">{hero.eyebrow}</p>
          <p
            class="mt-4 inline-flex rounded-full border border-[rgb(17_17_17/0.08)] bg-[rgb(255_255_255/0.66)] px-4 py-2 font-mono text-[1.05rem] text-ink-950 shadow-(--shadow-soft)"
          >
            {hero.code}
          </p>
          <h1 class="title-xl mt-6">{hero.title}</h1>
          <p class="mt-6 text-xl leading-8 text-ink-800 md:text-2xl">
            {hero.intro}
          </p>
          <div class="body-copy mt-6 space-y-4">
            {hero.description.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={hero.primaryCta.href} class="button button-primary">
              {hero.primaryCta.label}
            </a>
            <a href={hero.secondaryCta.href} class="button button-secondary">
              {hero.secondaryCta.label}
            </a>
            <a href={hero.tertiaryCta.href} class="button button-ghost">
              {hero.tertiaryCta.label}
            </a>
          </div>
          <div class="mt-10 grid gap-3 sm:grid-cols-3">
            {
              hero.stats.map((stat) => (
                <div class="card p-4">
                  <p class="text-xs uppercase tracking-[0.18em] text-stone-500">
                    {stat.label}
                  </p>
                  <p class="mt-2 font-display text-lg font-semibold text-ink-950">
                    {stat.value}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="card p-8 reveal [animation-delay:120ms]">
          <p class="eyebrow">{hero.founderCard.eyebrow}</p>
          <h2
            class="mt-4 font-display text-2xl font-semibold tracking-[-0.03em] text-ink-950"
          >
            {hero.founderCard.title}
          </h2>
          <div class="body-copy mt-6 space-y-1">
            {
              hero.founderCard.description.map((paragraph) => (
                <p>{paragraph}</p>
              ))
            }
          </div>
          <ul class="mt-6 space-y-3 text-sm text-ink-950">
            {
              hero.founderCard.highlights.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-accent-500" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </section>

    <section class="section section-border">
      <div class="shell space-y-10">
        <SectionHeading
          eyebrow={pages.home.pillars.eyebrow}
          title={pages.home.pillars.title}
          body={pages.home.pillars.intro}
        />

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {
            pages.home.pillars.items.map((pillar, index) => (
              <article
                class={`card p-6 reveal ${
                  index % 3 === 1 ? 'md:translate-y-6' : ''
                } ${index % 3 === 2 ? 'xl:translate-y-10' : ''}`}
              >
                <h3 class="font-display text-2xl font-semibold tracking-[-0.03em] text-ink-950">
                  {pillar.title}
                </h3>
                <p class="body-copy mt-3">{pillar.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell grid gap-10">
        <SectionHeading
          eyebrow={pages.home.eventHighlight.eyebrow}
          title={pages.home.eventHighlight.title}
          body={pages.home.eventHighlight.intro}
        />
        <EventCard
          event={pages.home.eventHighlight.event}
          variant="highlight"
          labels={shared.labels}
        />
      </div>
    </section>

    <JoinCta join={shared.join} links={shared.ctaLinks} />
  </main>

  <SiteFooter
    brand={shared.brand}
    tagline={shared.tagline}
    nav={shared.nav}
    social={shared.social}
    footer={shared.footer}
  />
</BaseLayout>
