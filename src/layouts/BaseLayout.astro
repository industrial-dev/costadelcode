---
import '../styles/global.css';
import { siteLocale } from '../data/i18n';
import { withBasePath } from '../utils/paths';
import ResourcesWidget from '../components/ResourcesWidget';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  robots?: string;
  showIntro?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  robots = 'index,follow',
  showIntro = false,
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(withBasePath(canonicalPath), Astro.site).href
  : null;
const faviconPath = withBasePath('/favicon.svg');
const introVideoPath = withBasePath('/intro/costa-del-code-intro.mp4');
const introDecisionScript = `
(() => {
  const storageKey = 'cdc-intro-seen-v2';
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const forceIntro = new URLSearchParams(window.location.search).get('intro') === '1';
  let hasSeenIntro = false;

  try {
    hasSeenIntro = window.localStorage.getItem(storageKey) === '1';
  } catch {
    hasSeenIntro = false;
  }

  if (forceIntro) {
    document.documentElement.dataset.intro = 'pending';
    return;
  }

  if (!prefersReducedMotion && !hasSeenIntro) {
    document.documentElement.dataset.intro = 'pending';
    return;
  }

  document.documentElement.dataset.intro = 'done';
})();`;
const introPlaybackScript = `
(() => {
  const storageKey = 'cdc-intro-seen-v2';
  const root = document.documentElement;
  const overlay = document.getElementById('site-intro');
  const video = document.getElementById('site-intro-video');
  const shell = document.getElementById('page-shell');

  if (!overlay || !video || !shell) {
    return;
  }

  const finishIntro = () => {
    root.dataset.intro = 'done';
    overlay.dataset.state = 'exiting';

    try {
      window.localStorage.setItem(storageKey, '1');
    } catch {
      // Ignore storage failures and just continue into the site.
    }

    window.setTimeout(() => {
      overlay.hidden = true;
    }, 520);
  };

  if (root.dataset.intro !== 'pending') {
    overlay.hidden = true;
    return;
  }

  overlay.hidden = false;
  overlay.dataset.state = 'active';

  if (!video.currentSrc && video.dataset.src) {
    video.src = video.dataset.src;
    video.load();
  }

  const playPromise = video.play();

  if (playPromise && typeof playPromise.catch === 'function') {
    playPromise.catch(() => {
      finishIntro();
    });
  }

  video.addEventListener('ended', finishIntro, { once: true });
  video.addEventListener('error', finishIntro, { once: true });
})();`;
---

<!doctype html>
<html lang={siteLocale.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content={robots} />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteLocale.ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    {showIntro && <script is:inline set:html={introDecisionScript} />}
    <title>{title}</title>
  </head>
  <body class="antialiased">
    {
      showIntro && (
        <div id="site-intro" class="site-intro" hidden aria-hidden="true">
          <video
            id="site-intro-video"
            class="site-intro__video"
            data-src={introVideoPath}
            muted
            playsinline
            preload="none"
          />
        </div>
      )
    }
    <div id="page-shell" data-intro-shell>
      <slot />
    </div>
    <ResourcesWidget client:load />
    {showIntro && <script is:inline set:html={introPlaybackScript} />}
  </body>
</html>
