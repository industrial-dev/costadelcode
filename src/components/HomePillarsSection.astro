---
import SectionHeading from './SectionHeading.astro';
import PillarIcon from './PillarIcon.astro';
import type { HomePage } from '../data/site-content';

interface Props {
  pillars: HomePage['pillars'];
}

const { pillars } = Astro.props as Props;
const itemCount = pillars.items.length;
const smLastRowStart = itemCount - (itemCount % 2 || 2);
const lgLastRowStart = itemCount - (itemCount % 3 || 3);
---

<section class="section section-border relative overflow-hidden">
  <div
    class="pointer-events-none absolute -right-24 top-16 h-72 w-72 rounded-full bg-[rgb(243_212_88/0.16)] blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-24 bottom-8 h-64 w-64 rounded-full bg-[rgb(255_255_255/0.68)] blur-3xl"
  >
  </div>

  <div class="shell relative space-y-12">
    <SectionHeading
      eyebrow={pillars.eyebrow}
      title={pillars.title}
      align="center"
    />

    <div class="card overflow-hidden rounded-4xl bg-[rgb(255_255_255/0.54)]">
      <div class="grid grid-cols-1 text-center sm:grid-cols-2 lg:grid-cols-3">
        {
          pillars.items.map((pillar, index) => (
            <article
              class:list={[
                'group relative min-h-68 p-7 reveal transition duration-200 hover:bg-cream-50 sm:p-8 lg:p-10',
                index % 2 === 0 ? 'sm:border-r' : null,
                index < smLastRowStart ? 'sm:border-b' : null,
                index % 3 !== 2 ? 'lg:border-r' : 'lg:border-r-0',
                index < lgLastRowStart ? 'lg:border-b' : 'lg:border-b-0',
              ]}
              style={`animation-delay:${index * 70}ms`}
            >
              <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-linear-to-r from-transparent via-[rgb(17_17_17/0.08)] to-transparent opacity-0 transition duration-200 group-hover:opacity-100" />
              <PillarIcon icon={pillar.icon} />
              <h3 class="mt-8 font-display text-2xl font-semibold tracking-[-0.04em] text-ink-950">
                {pillar.title}
              </h3>
              <p class="mx-auto mt-4 max-w-[18rem] text-[0.98rem] leading-7 text-[rgb(35_33_29/0.74)]">
                {pillar.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
