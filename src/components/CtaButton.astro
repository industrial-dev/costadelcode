---
import type { CtaLink } from '../data/site-content';
import { getButtonVariantClass } from '../utils/buttons';
import { withBasePath } from '../utils/paths';

interface Props {
  link: CtaLink;
  class?: string;
}

const { link, class: className = '' } = Astro.props as Props;
const buttonClass = getButtonVariantClass(link.variant, link.platform);
---

<a
  href={withBasePath(link.href)}
  class:list={['button', buttonClass, className]}
>
  {
    link.platform === 'telegram' && (
      <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M21.9 4.2 18.7 20c-.2 1-1 1.2-1.8.7l-5-3.7-2.4 2.3c-.3.3-.5.5-1 .5l.4-5.1 9.3-8.4c.4-.4-.1-.6-.6-.2L6.1 13.3l-4.9-1.5c-1.1-.3-1.1-1.1.2-1.6l18.7-7.1c.9-.3 1.7.2 1.8 1.1Z"
        />
      </svg>
    )
  }
  {
    link.platform === 'instagram' && (
      <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7.5 2.75h9A4.75 4.75 0 0 1 21.25 7.5v9a4.75 4.75 0 0 1-4.75 4.75h-9A4.75 4.75 0 0 1 2.75 16.5v-9A4.75 4.75 0 0 1 7.5 2.75Z"
        />
        <path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M8.75 12a3.25 3.25 0 1 0 6.5 0 3.25 3.25 0 0 0-6.5 0Z"
        />
        <path
          fill="currentColor"
          d="M17.55 6.75a.85.85 0 1 1-1.7 0 .85.85 0 0 1 1.7 0Z"
        />
      </svg>
    )
  }
  <span>{link.label}</span>
</a>
