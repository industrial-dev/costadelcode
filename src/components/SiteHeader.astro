---
import type { CtaLink, NavItem } from '../data/site-content';
import CtaButton from './CtaButton.astro';
import BrandLogo from './BrandLogo.astro';
import { withBasePath } from '../utils/paths';
import homeIcon from '../assets/icons/nav/home.svg?raw';
import communityIcon from '../assets/icons/nav/community.svg?raw';
import eventsIcon from '../assets/icons/nav/events.svg?raw';
import faqIcon from '../assets/icons/nav/faq.svg?raw';

interface Props {
  brand: string;
  nav: NavItem[];
  ctas: CtaLink[];
  menuLabel: string;
  navigationLabel: string;
}

const { brand, nav, ctas, menuLabel, navigationLabel } = Astro.props as Props;
const homeHref = withBasePath(nav[0]?.href ?? '/');

const navIcons: Record<string, string> = {
  '/': homeIcon,
  '/community/': communityIcon,
  '/events/': eventsIcon,
  '/faq/': faqIcon,
};
---

<header
  class="site-header sticky top-0 z-40 border-b border-(--border-soft) bg-[rgb(246_241_232/0.92)] backdrop-blur-[18px]"
>
  <nav
    class="shell flex min-h-19 items-center justify-between gap-4"
    aria-label={navigationLabel}
  >
    <a
      href={homeHref}
      class="font-logo text-[clamp(1.15rem,0.92rem+0.7vw,1.7rem)] leading-none font-bold tracking-[-0.2em] whitespace-nowrap uppercase text-ink-950 [word-spacing:0.08em]"
      aria-label={brand}
    >
      <BrandLogo brand={brand} />
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {
        nav.map((item) => (
          <a
            href={withBasePath(item.href)}
            class="nav-link flex items-center gap-1.5"
          >
            <Fragment set:html={navIcons[item.href] ?? ''} />
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="hidden items-center gap-2 md:flex">
      {ctas.map((cta) => <CtaButton link={cta} />)}
    </div>

    <details class="relative md:hidden">
      <summary class="button button-ghost px-4 py-2">{menuLabel}</summary>
      <div class="menu-panel">
        <div class="grid gap-3">
          {
            nav.map((item) => (
              <a
                href={withBasePath(item.href)}
                class="menu-link flex items-center gap-2"
              >
                <Fragment set:html={navIcons[item.href] ?? ''} />
                {item.label}
              </a>
            ))
          }
          {ctas.map((cta) => <CtaButton link={cta} class="w-full" />)}
        </div>
      </div>
    </details>
  </nav>
</header>
