---
import type { CtaLink, NavItem } from '../data/site-content';
import CtaButton from './CtaButton.astro';
import { withBasePath } from '../utils/paths';
import homeIcon from '../assets/icons/nav/home.svg?raw';
import communityIcon from '../assets/icons/nav/community.svg?raw';
import eventsIcon from '../assets/icons/nav/events.svg?raw';
import faqIcon from '../assets/icons/nav/faq.svg?raw';

interface Props {
  brand: string;
  nav: NavItem[];
  cta: CtaLink;
  menuLabel: string;
  navigationLabel: string;
}

const { brand, nav, cta, menuLabel, navigationLabel } = Astro.props as Props;
const homeHref = withBasePath(nav[0]?.href ?? '/');

const navIcons: Record<string, string> = {
  '/': homeIcon,
  '/community/': communityIcon,
  '/events/': eventsIcon,
  '/faq/': faqIcon,
};
const firstBrandHighlight = brand.indexOf('C');
const secondBrandHighlight = brand.indexOf('C', firstBrandHighlight + 1);
const canHighlightBrand = firstBrandHighlight >= 0 && secondBrandHighlight >= 0;
const brandSegments = canHighlightBrand
  ? [
      { text: brand.slice(0, firstBrandHighlight), highlighted: false },
      { text: brand[firstBrandHighlight], highlighted: true },
      {
        text: brand.slice(firstBrandHighlight + 1, secondBrandHighlight),
        highlighted: false,
      },
      { text: brand[secondBrandHighlight], highlighted: true },
      { text: brand.slice(secondBrandHighlight + 1), highlighted: false },
    ].filter(({ text }) => text.length > 0)
  : [{ text: brand, highlighted: false }];
---

<header
  class="site-header sticky top-0 z-40 border-b border-(--border-soft) bg-[rgb(246_241_232/0.92)] backdrop-blur-[18px]"
>
  <nav
    class="shell flex min-h-19 items-center justify-between gap-4"
    aria-label={navigationLabel}
  >
    <a
      href={homeHref}
      class="font-logo text-[clamp(1.15rem,0.92rem+0.7vw,1.7rem)] leading-none font-bold tracking-[-0.2em] whitespace-nowrap uppercase text-ink-950 [word-spacing:0.08em]"
      aria-label={brand}
    >
      <span class="inline-block origin-left scale-x-[0.86]" aria-hidden="true">
        {
          brandSegments.map(({ text, highlighted }) => (
            <span
              class:list={[
                highlighted
                  ? 'inline-block origin-bottom translate-y-[0.04em] scale-x-115 scale-y-130 text-accent-500 mr-[-0.3em]'
                  : null,
              ]}
            >
              {text}
            </span>
          ))
        }
      </span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {
        nav.map((item) => (
          <a
            href={withBasePath(item.href)}
            class="nav-link flex items-center gap-1.5"
          >
            <Fragment set:html={navIcons[item.href] ?? ''} />
            {item.label}
          </a>
        ))
      }
    </div>

    <CtaButton link={cta} class="hidden md:inline-flex" />

    <details class="relative md:hidden">
      <summary class="button button-ghost px-4 py-2">{menuLabel}</summary>
      <div class="menu-panel">
        <div class="grid gap-3">
          {
            nav.map((item) => (
              <a
                href={withBasePath(item.href)}
                class="menu-link flex items-center gap-2"
              >
                <Fragment set:html={navIcons[item.href] ?? ''} />
                {item.label}
              </a>
            ))
          }
          <CtaButton link={cta} class="w-full" />
        </div>
      </div>
    </details>
  </nav>
</header>
