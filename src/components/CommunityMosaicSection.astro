---
import type { FounderCard } from '../data/site-content';

interface Props {
  founderCard: FounderCard;
}

const { founderCard } = Astro.props as Props;
const { eyebrow, title, description, highlights, mosaic } = founderCard;
---

<section class="section section-border">
  <div class="shell">
    <div class="flex flex-col gap-2.5">
      <!-- FILA 1: Card principal + Card connect -->
      <div class="grid gap-2.5 sm:grid-cols-[3fr_2fr]">
        <article
          class="relative overflow-hidden rounded-[1.6rem] border bg-white/80 shadow-(--shadow-card) backdrop-blur-sm p-7 sm:p-9 reveal"
        >
          <p class="eyebrow">{eyebrow}</p>
          <h2
            class="mt-4 font-display text-[clamp(2.6rem,6vw,4.2rem)] leading-[0.88] font-semibold tracking-[-0.05em] text-code-green"
          >
            {mosaic.headline}
          </h2>
          <div class="mt-6 border-t border-(--border-soft) pt-5">
            <p
              class="font-display text-base font-semibold tracking-[-0.02em] text-ink-950"
            >
              {title}
            </p>
            <div
              class="mt-2 space-y-1.5 text-sm leading-6 font-semibold text-ink-800"
            >
              {description.map((p) => <p>{p}</p>)}
            </div>
          </div>
        </article>

        <article
          class="relative overflow-hidden rounded-[1.6rem] bg-code-green p-7 sm:p-9 reveal"
        >
          <p class="font-mono text-2xl leading-none text-code-lime">
            {mosaic.connectLabel}
          </p>
          <p
            class="mt-5 font-display text-[clamp(1.6rem,4vw,2.4rem)] leading-[1.1] font-semibold tracking-[-0.03em] text-white"
          >
            {mosaic.connectDescription}
          </p>
          <div
            class="pointer-events-none absolute -right-6 -bottom-6 h-36 w-36 rounded-full border border-code-lime/20 opacity-40"
            aria-hidden="true"
          >
          </div>
        </article>
      </div>

      <!-- FILA 2: Tres cards medianas -->
      <div class="grid gap-2.5 sm:grid-cols-3">
        <article class="rounded-[1.6rem] bg-accent-500 p-6 sm:p-7 reveal">
          <svg
            class="h-5 w-5 text-ink-950/40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <h3
            class="mt-6 font-display text-[1.65rem] leading-[0.9] font-semibold tracking-[-0.04em] text-ink-950"
          >
            {mosaic.offlineTitle}
          </h3>
          <p
            class="mt-4 text-sm leading-6 font-semibold text-ink-800"
            set:html={highlights.offline}
          />
        </article>

        <article
          class="rounded-[1.6rem] border bg-cream-100 shadow-(--shadow-card) p-6 sm:p-7 reveal"
        >
          <svg
            class="h-5 w-5 text-code-green"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="18" cy="18" r="3"></circle>
            <circle cx="6" cy="6" r="3"></circle>
            <path d="M6 21V9a9 9 0 0 0 9 9"></path>
          </svg>
          <h3
            class="mt-6 font-display text-[1.65rem] leading-[0.9] font-semibold tracking-[-0.04em] text-code-green"
          >
            {mosaic.docTitle}
          </h3>
          <p class="mt-4 text-sm leading-6 font-semibold text-ink-800">
            {highlights.sync}
          </p>
        </article>

        <article
          class="rounded-[1.6rem] border bg-cream-200 shadow-(--shadow-card) p-6 sm:p-7 reveal"
        >
          <svg
            class="h-5 w-5 text-stone-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <h3
            class="mt-6 font-display text-[1.65rem] leading-[0.9] font-semibold tracking-[-0.04em] text-ink-950"
          >
            {mosaic.communityTitle}
          </h3>
          <p class="mt-4 text-sm leading-6 font-semibold text-ink-800">
            {highlights.community}
          </p>
        </article>
      </div>

      <!-- FILA 3: Dos cards de terminal -->
      <div class="grid gap-2.5 sm:grid-cols-[3fr_2fr]">
        <article
          class="rounded-[1.6rem] border bg-accent-500/15 shadow-(--shadow-card) p-6 sm:p-7 reveal"
        >
          <div
            class="flex items-center gap-3 rounded-2xl bg-ink-950 px-5 py-3.5 font-mono text-lg leading-none text-cream-50"
          >
            <span class="text-code-lime shrink-0">$</span>
            <span class="truncate text-white/80">{mosaic.pushCommand}</span>
          </div>
          <p class="mt-5 text-sm leading-6 font-semibold text-ink-950">
            {highlights.push}
          </p>
        </article>

        <article
          class="relative overflow-hidden rounded-[1.6rem] border bg-code-green/10 shadow-(--shadow-card) p-6 sm:p-7 reveal"
        >
          <div
            class="flex items-center gap-3 rounded-2xl bg-ink-950 px-5 py-3.5 font-mono text-lg leading-none text-cream-50"
          >
            <span class="text-code-lime shrink-0">$</span>
            <span class="text-white/80">{mosaic.feedbackCommand}</span>
          </div>
          <p class="mt-5 text-sm leading-6 font-semibold text-ink-800">
            {highlights.feedback}
          </p>
          <div
            class="pointer-events-none absolute -right-8 -bottom-8 h-28 w-28 rounded-full bg-code-green/10"
            aria-hidden="true"
          >
          </div>
        </article>
      </div>
    </div>
  </div>
</section>
