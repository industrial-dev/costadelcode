---
import { homeContent } from '../data/home-content';
import type { LocaleCode } from '../data/i18n';

interface Props {
  locale: LocaleCode;
}

const { locale } = Astro.props;
const content = homeContent[locale];

const reveal = 'animate-[fade-rise_720ms_cubic-bezier(0.22,1,0.36,1)_both]';
const shell = 'mx-auto w-[min(1180px,calc(100%-2rem))]';
const shellNarrow = 'mx-auto w-[min(860px,calc(100%-2rem))]';
const section = 'py-20';
const sectionBorder = 'border-y border-[var(--border-soft)]';
const eyebrow =
  'font-display text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-stone-500';
const bodyCopy = 'text-[1.02rem] leading-8 text-[rgb(35_33_29_/_0.78)]';
const title =
  'font-display text-4xl leading-tight font-semibold tracking-[-0.03em] text-ink-950 md:text-5xl';
const card =
  'rounded-[1.75rem] border border-[var(--border-soft)] bg-[rgb(255_255_255_/_0.52)] p-6 shadow-[var(--shadow-card)] backdrop-blur-sm';
const buttonBase =
  'inline-flex items-center justify-center rounded-full border px-5 py-3 text-sm font-semibold transition duration-150';
const buttonPrimary = `${buttonBase} border-ink-950 bg-ink-950 text-cream-50 hover:bg-[rgb(17_17_17_/_0.9)]`;
const buttonSecondary = `${buttonBase} border-[var(--border-soft)] bg-[rgb(255_255_255_/_0.6)] text-ink-950 hover:border-[rgb(17_17_17_/_0.24)] hover:bg-white`;
---

<main class="relative">
  <header
    class="sticky top-0 z-40 border-b border-(--border-soft) bg-[rgb(246_241_232/0.88)] backdrop-blur-[18px] transition duration-180 data-[condensed=true]:bg-[rgb(246_241_232/0.94)] data-[condensed=true]:shadow-[0_10px_30px_rgb(17_17_17/0.04)]"
    data-site-header
    data-condensed="false"
  >
    <nav
      class="mx-auto flex min-h-19 w-[min(1120px,calc(100%-2rem))] items-center justify-between gap-4 transition-[min-height] duration-180 data-[condensed=true]:min-h-16"
      data-site-nav
    >
      <a
        href="#hero"
        class="font-mono text-[clamp(1.6rem,1.4rem+0.6vw,2rem)] leading-none whitespace-nowrap text-ink-950"
      >
        {content.brand}
      </a>

      <div class="hidden items-center gap-6 md:flex">
        {
          content.nav.map((item) => (
            <a
              href={item.href}
              class="relative text-[0.92rem] font-semibold text-[rgb(35_33_29/0.72)] transition hover:text-ink-950 after:absolute after:bottom-[-0.35rem] after:left-0 after:h-px after:w-full after:origin-left after:scale-x-[0.2] after:bg-ink-950 after:opacity-0 after:transition after:duration-180 hover:after:scale-x-100 hover:after:opacity-75"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <a href="#join" class={`${buttonPrimary} px-4 py-2.5 text-[0.92rem]`}>
        {content.hero.primary}
      </a>
    </nav>
  </header>

  <section id="hero" class={`${section} pb-24 pt-16 ${reveal}`}>
    <div
      class={`${shell} grid items-end gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]`}
    >
      <div class="max-w-160">
        <p class={eyebrow}>{content.hero.eyebrow}</p>
        <p
          class="mt-4 inline-flex rounded-full border border-[rgb(17_17_17/0.08)] bg-[rgb(255_255_255/0.66)] px-4 py-2 font-mono text-[1.05rem] text-ink-950 shadow-(--shadow-soft)"
        >
          {content.hero.code}
        </p>
        <h1
          class="mt-6 font-display text-5xl leading-[0.96] font-semibold tracking-tighter text-ink-950 md:text-7xl"
        >
          {content.hero.title}
        </h1>
        <p class="mt-6 max-w-152 text-xl leading-8 text-ink-800 md:text-2xl">
          {content.hero.intro}
        </p>
        <div class={`${bodyCopy} mt-6 max-w-184 space-y-4`}>
          {content.hero.description.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#join" class={buttonPrimary}>{content.hero.primary}</a>
          <a href="#community" class={buttonSecondary}
            >{content.hero.secondary}</a
          >
        </div>
      </div>

      <aside
        class={`${card} ${reveal} [animation-delay:180ms] lg:translate-y-6`}
      >
        <p
          class="font-display text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-stone-500"
        >
          {content.origin.eyebrow}
        </p>
        <h2
          class="mt-4 max-w-[20rem] font-display text-3xl leading-tight font-semibold tracking-[-0.03em] text-ink-950"
        >
          {content.origin.title}
        </h2>
        <p
          class="mt-6 border-t border-[rgb(17_17_17/0.08)] pt-4 text-[1.02rem] leading-7 text-[rgb(35_33_29/0.78)]"
        >
          {content.origin.description}
        </p>
      </aside>
    </div>
  </section>

  <section
    id="community"
    class={`${section} ${sectionBorder} ${reveal} [animation-delay:90ms]`}
  >
    <div class={`${shell} grid gap-8`}>
      <div class="max-w-160">
        <p class={eyebrow}>{content.community.eyebrow}</p>
        <h2 class={`${title} mt-4`}>{content.community.title}</h2>
        <p class={`${bodyCopy} mt-5`}>{content.community.intro}</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          content.community.audience.map((item, index) => (
            <article
              class={`${card} ${reveal} ${index === 1 ? 'md:translate-y-8' : ''} ${index === 2 ? 'xl:translate-y-16' : ''}`}
            >
              <p class="font-display text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-stone-500">
                {content.community.audienceEyebrow}
              </p>
              <h3 class="mt-4 font-display text-2xl leading-tight font-semibold tracking-[-0.03em] text-ink-950">
                {item.title}
              </h3>
              <p class={`${bodyCopy} mt-4`}>{item.description}</p>
            </article>
          ))
        }
      </div>

      <p class={`${bodyCopy} max-w-208`}>
        {content.community.closing}
      </p>
    </div>
  </section>

  <section id="meetups" class={`${section} ${reveal} [animation-delay:90ms]`}>
    <div class={`${shell} grid gap-8`}>
      <div class="max-w-160">
        <p class={eyebrow}>{content.meetups.eyebrow}</p>
        <h2 class={`${title} mt-4`}>{content.meetups.title}</h2>
        <p class={`${bodyCopy} mt-5`}>{content.meetups.intro}</p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          content.meetups.items.map((item) => (
            <article class={`${card} ${reveal}`}>
              <p class="font-display text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-stone-500">
                {item.meta}
              </p>
              <h3 class="mt-4 font-display text-2xl leading-tight font-semibold tracking-[-0.03em] text-ink-950">
                {item.title}
              </h3>
              <p class={`${bodyCopy} mt-4`}>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="join"
    class={`${section} pb-24 border-t border-(--border-soft) ${reveal} [animation-delay:180ms]`}
  >
    <div class={shellNarrow}>
      <div class="mx-auto max-w-184 text-center">
        <p class={eyebrow}>{content.cta.eyebrow}</p>
        <p
          class="mt-4 inline-flex rounded-full border border-[rgb(17_17_17/0.08)] bg-[rgb(255_255_255/0.66)] px-4 py-2 font-mono text-[1.05rem] text-ink-950 shadow-(--shadow-soft)"
        >
          {content.cta.code}
        </p>
        <h2 class={`${title} mt-6`}>{content.cta.title}</h2>
        <p class={`${bodyCopy} mt-5`}>{content.cta.description}</p>
        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          {
            content.cta.links.map((link, index) => (
              <a
                href={link.href}
                class={index === 0 ? buttonPrimary : buttonSecondary}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t border-(--border-soft) py-8">
    <div class={`${shell} grid gap-3 md:grid-cols-[1fr_auto] md:items-center`}>
      <p class="font-display text-lg font-semibold text-ink-950">
        {content.footer.copy}
      </p>
      <p
        class="font-display text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-stone-500"
      >
        {content.footer.note}
      </p>
    </div>
  </footer>
</main>

<script>
  const siteHeader = document.querySelector('[data-site-header]');
  const siteNav = document.querySelector('[data-site-nav]');

  if (siteHeader instanceof HTMLElement && siteNav instanceof HTMLElement) {
    let lastCondensed = window.scrollY > 20;

    const syncHeader = () => {
      const condensed = window.scrollY > 20;

      if (condensed === lastCondensed) {
        return;
      }

      lastCondensed = condensed;
      siteHeader.dataset.condensed = condensed ? 'true' : 'false';
      siteNav.dataset.condensed = condensed ? 'true' : 'false';
    };

    siteHeader.dataset.condensed = lastCondensed ? 'true' : 'false';
    siteNav.dataset.condensed = lastCondensed ? 'true' : 'false';
    syncHeader();
    window.addEventListener('scroll', syncHeader, { passive: true });
  }
</script>
