---
import type { HomePage } from '../data/site-content';

interface Props {
  founderCard: HomePage['hero']['founderCard'];
}

const { founderCard } = Astro.props as Props;
const { highlights, mosaic } = founderCard;
---

<section class="section section-border relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-x-0 top-12 h-48 bg-[radial-gradient(circle_at_center,rgb(243_212_88/0.18),transparent_62%)]"
  >
  </div>

  <div class="shell">
    <div
      class="relative overflow-hidden rounded-[2.25rem] bg-ink-950 p-3 shadow-[0_28px_80px_rgb(17_17_17/0.18)] reveal sm:p-4 lg:p-5"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.18] bg-[linear-gradient(90deg,rgb(246_241_232/0.18)_1px,transparent_1px),linear-gradient(180deg,rgb(246_241_232/0.14)_1px,transparent_1px)] bg-size-[28px_28px]"
      >
      </div>

      <div
        class="relative grid gap-3 lg:grid-cols-12 lg:auto-rows-[minmax(190px,auto)]"
      >
        <article
          class="relative overflow-hidden rounded-[1.6rem] bg-cream-50 p-6 sm:p-8 lg:col-span-8 lg:min-h-77.5"
        >
          <div class="max-w-2xl">
            <p class="eyebrow">{founderCard.eyebrow}</p>
            <h2
              class="mt-5 max-w-[10ch] font-display text-[clamp(3.1rem,8vw,7.5rem)] leading-[0.82] font-semibold tracking-[-0.09em] text-code-green"
            >
              {mosaic.headline}
            </h2>
            <p
              class="mt-6 font-display text-xl font-semibold tracking-[-0.04em] text-ink-950 sm:text-2xl"
            >
              {founderCard.title}
            </p>
            <div
              class="mt-4 max-w-lg space-y-2 text-sm leading-6 font-semibold text-ink-800"
            >
              {founderCard.description.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>

          <div
            class="absolute right-6 bottom-6 hidden items-end gap-2 text-ink-950 sm:flex"
            aria-hidden="true"
          >
            <div
              class="h-14 w-14 rounded-full border-2 border-ink-950 bg-code-lime"
            >
            </div>
            <div
              class="h-17 w-17 rounded-full border-2 border-ink-950 bg-cream-100"
            >
            </div>
            <div
              class="h-12 w-12 rounded-full border-2 border-ink-950 bg-code-red"
            >
            </div>
          </div>
        </article>

        <article
          class="relative overflow-hidden rounded-[1.6rem] bg-code-green p-6 text-cream-50 sm:p-8 lg:col-span-4 lg:min-h-77.5"
        >
          <div
            class="absolute -top-20 -right-16 h-52 w-52 rounded-full border-28 border-code-lime/55"
          >
          </div>
          <p class="font-mono text-2xl leading-none text-code-lime">
            {mosaic.connectLabel}
          </p>
          <svg
            class="mx-auto mt-8 h-36 w-full max-w-sm text-cream-50 sm:h-44"
            viewBox="0 0 320 180"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M26 74 98 24l55 76-72 50L26 74Z"
              fill="currentColor"
              opacity="0.96"></path>
            <path
              d="M296 73 222 22l-55 78 73 50 56-77Z"
              fill="currentColor"
              opacity="0.96"></path>
            <path
              class="text-code-lime"
              d="M127 103c21-29 54-29 75 0l-20 28c-12 15-31 15-43 0l-12-28Z"
              stroke="currentColor"
              stroke-width="8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M111 96c30 20 65 22 99 0M130 132c22 14 45 14 66 0"
              stroke="currentColor"
              stroke-width="8"
              stroke-linecap="round"></path>
            <path
              class="text-code-lime"
              d="M73 135c-18 4-34 17-45 34M247 135c18 4 34 17 45 34"
              stroke="currentColor"
              stroke-width="7"
              stroke-linecap="round"></path>
          </svg>
          <p class="relative mt-6 max-w-sm text-lg leading-7 font-semibold">
            {mosaic.connectDescription}
          </p>
        </article>

        <article
          class="rounded-[1.6rem] bg-code-red p-6 text-cream-50 sm:p-7 lg:col-span-4"
        >
          <div
            class="flex items-center justify-between font-mono text-xl leading-none"
          >
            <span>{mosaic.offlineNumber}</span>
            <span>{mosaic.offlineLabel}</span>
          </div>
          <h3
            class="mt-11 font-display text-4xl leading-none font-semibold tracking-[-0.06em]"
          >
            {mosaic.offlineTitle}
          </h3>
          <p class="mt-5 text-sm leading-6 font-semibold text-cream-50/88">
            {highlights.offline}
          </p>
        </article>

        <article class="rounded-[1.6rem] bg-cream-50 p-6 sm:p-7 lg:col-span-4">
          <div
            class="mx-auto mt-2 flex h-18 w-18 items-center justify-center rounded-3xl bg-code-red text-cream-50"
            aria-hidden="true"
          >
            <svg class="h-10 w-10" viewBox="0 0 48 48" fill="none">
              <path
                d="M10 24h28"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"></path>
              <path
                d="M24 10v28"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"></path>
              <path
                d="m15 15 18 18"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"></path>
              <path
                d="m33 15-18 18"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3
            class="mt-7 text-center font-display text-5xl leading-none font-semibold tracking-[-0.08em] text-code-red"
          >
            {mosaic.docTitle}
          </h3>
          <p
            class="mx-auto mt-5 max-w-xs text-center text-sm leading-6 font-semibold text-ink-800"
          >
            {highlights.sync}
          </p>
        </article>

        <article
          class="relative overflow-hidden rounded-[1.6rem] bg-cream-50 p-6 sm:p-7 lg:col-span-4 lg:row-span-2"
        >
          <p
            class="font-display text-[clamp(3rem,6vw,5.4rem)] leading-[0.82] font-semibold -tracking-widest text-code-red"
          >
            {mosaic.communityTitle}
          </p>
          <p class="mt-5 font-mono text-2xl text-code-red">
            {mosaic.communityTag}
          </p>
          <div
            class="absolute right-4 bottom-4 left-4 flex items-end justify-center"
            aria-hidden="true"
          >
            <div
              class="h-28 w-24 rounded-t-full border-[3px] border-ink-950 bg-code-red"
            >
            </div>
            <div
              class="-ml-4 h-36 w-28 rounded-t-full border-[3px] border-ink-950 bg-cream-100"
            >
            </div>
            <div
              class="-ml-4 h-31 w-24 rounded-t-full border-[3px] border-ink-950 bg-code-green"
            >
            </div>
          </div>
        </article>

        <article class="rounded-[1.6rem] bg-cream-50 p-6 sm:p-7 lg:col-span-5">
          <div
            class="rounded-[1.35rem] bg-code-green px-5 py-4 font-mono text-xl leading-none text-cream-50"
          >
            {mosaic.pushCommand}
          </div>
          <p class="mt-6 text-sm leading-6 font-semibold text-ink-950">
            {highlights.push}
          </p>
        </article>

        <article
          class="relative overflow-hidden rounded-[1.6rem] bg-code-green p-6 text-cream-50 sm:p-7 lg:col-span-3"
        >
          <div
            class="absolute -right-10 -bottom-10 h-32 w-32 rounded-full bg-code-lime/60"
          >
          </div>
          <div
            class="relative rounded-[1.35rem] bg-ink-950 px-5 py-4 font-mono text-xl leading-none shadow-(--shadow-card)"
          >
            {mosaic.feedbackCommand}
          </div>
          <p
            class="relative mt-6 text-sm leading-6 font-semibold text-cream-50/90"
          >
            {highlights.feedback}
          </p>
        </article>
      </div>
    </div>
  </div>
</section>
