---
import type { HomePage } from '../data/site-content';
import GlobeHero from './GlobeHero';

interface Props {
  hero: HomePage['hero'];
}

const { hero } = Astro.props as Props;
---

<section class="section relative overflow-hidden pt-14">
  <div
    class="hero-glow-warm pointer-events-none absolute -right-28 top-12 h-72 w-72 rounded-full blur-3xl animate-[float-slow_10s_ease-in-out_infinite]"
  >
  </div>
  <div
    class="hero-glow-soft pointer-events-none absolute -left-24 bottom-8 h-64 w-64 rounded-full blur-2xl"
  >
  </div>

  <div class="shell">
    <div
      class="flex flex-col items-center gap-10 md:flex-row md:items-center md:gap-12"
    >
      <div class="flex-1 text-center md:text-left">
        <p
          class="mt-4 inline-flex rounded-full border border-[rgb(17_17_17/0.08)] bg-[rgb(255_255_255/0.66)] px-4 py-2 font-mono text-[1.05rem] text-ink-950 shadow-(--shadow-soft)"
        >
          {hero.code}
        </p>
        <h1 class="title-xl mt-6">{hero.title}</h1>
        <p class="mt-6 text-xl leading-8 text-ink-800 md:text-2xl">
          {hero.intro}
        </p>
        <div class="body-copy mt-6 space-y-4">
          {hero.description.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="mt-10 grid grid-cols-1 gap-2.5 sm:grid-cols-[5fr_4fr]">
          <!-- Card oscura — protagonista -->
          <div
            class="relative overflow-hidden rounded-2xl bg-ink-950 p-6 sm:row-span-2"
          >
            <span
              aria-hidden="true"
              class="pointer-events-none absolute -left-3 -bottom-6 select-none font-display text-[10rem] font-black leading-none text-white opacity-[0.04]"
              >01</span
            >
            <span
              class="inline-flex rounded-full bg-accent-500/15 px-3 py-1 font-sans text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-accent-500"
            >
              {hero.stats[0].label}
            </span>
            <p
              class="mt-4 font-display text-[2.4rem] font-semibold leading-[1.05] tracking-[-0.03em] text-white sm:text-5xl"
            >
              {hero.stats[0].value}
            </p>
            <div
              class="absolute bottom-0 left-0 right-0 h-0.75 bg-linear-to-r from-accent-500/80 to-accent-600/40"
            >
            </div>
          </div>

          <!-- Card acento — amarillo -->
          <div class="relative overflow-hidden rounded-2xl bg-accent-500 p-6">
            <span
              aria-hidden="true"
              class="pointer-events-none absolute -right-3 -bottom-6 select-none font-display text-[8rem] font-black leading-none text-ink-950 opacity-[0.08]"
              >02</span
            >
            <p
              class="font-sans text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-ink-800/60"
            >
              {hero.stats[1].label}
            </p>
            <p
              class="mt-2 font-display text-[1.9rem] font-semibold leading-tight tracking-[-0.03em] text-ink-950"
            >
              {hero.stats[1].value}
            </p>
          </div>

          <!-- Card clara -->
          <div
            class="relative overflow-hidden rounded-2xl border border-(--border-soft) bg-[rgb(255_255_255/0.7)] p-6 backdrop-blur-sm"
          >
            <span
              aria-hidden="true"
              class="pointer-events-none absolute -right-3 -bottom-6 select-none font-display text-[8rem] font-black leading-none text-ink-950 opacity-[0.04]"
              >03</span
            >
            <p
              class="font-sans text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-stone-500"
            >
              {hero.stats[2].label}
            </p>
            <p
              class="mt-2 font-display text-[1.9rem] font-semibold leading-tight tracking-[-0.03em] text-ink-950"
            >
              {hero.stats[2].value}
            </p>
            {
              hero.stats[2].badge && (
                <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-cream-100 px-3 py-1 font-sans text-[0.65rem] font-semibold text-stone-500">
                  <svg
                    class="h-3 w-3 shrink-0 text-accent-600"
                    viewBox="0 0 12 12"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M2 6l3 3 5-5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {hero.stats[2].badge}
                </span>
              )
            }
          </div>
        </div>
      </div>
      <div class="w-full max-w-xs shrink-0 md:w-100 md:max-w-none">
        <GlobeHero client:visible />
      </div>
    </div>
  </div>
</section>
