---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: 'left' | 'center';
  size?: 'lg' | 'xl';
}

const { eyebrow, title, body, align, size } = Astro.props as Props;
const alignValue = align ?? 'left';
const sizeValue = size ?? 'lg';
const alignClass =
  alignValue === 'center' ? 'text-center mx-auto' : 'text-left';
const titleClass = sizeValue === 'xl' ? 'title-xl' : 'title-lg';
const bodyClass = alignValue === 'center' ? 'body-copy mx-auto' : 'body-copy';
---

<div class={`max-w-3xl ${alignClass}`.trim()}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class={`${titleClass} mt-4`}>{title}</h2>
  {body && <p class={`${bodyClass} mt-5`}>{body}</p>}
</div>
