---
import type { SetupCard } from '../data/site-content';
import { withBasePath } from '../utils/paths';

interface Props {
  setup: SetupCard;
}

const { setup } = Astro.props;
---

<article class="card overflow-hidden">
  <div class="bg-[rgb(255_255_255/0.7)] p-6">
    <figure class="space-y-3">
      <div
        class="overflow-hidden rounded-2xl border border-[rgb(17_17_17/0.08)] bg-white"
      >
        <img
          src={withBasePath(setup.imageSrc)}
          alt={setup.imageAlt}
          class="h-56 w-full object-cover"
          loading="lazy"
        />
      </div>
    </figure>
    <div class="mt-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-stone-500">
            {setup.name}
          </p>
          <h3
            class="mt-2 font-display text-2xl font-semibold tracking-[-0.03em] text-ink-950"
          >
            {setup.title}
          </h3>
        </div>
        <span class="tag">{setup.role}</span>
      </div>
      <blockquote
        class="mt-4 font-display text-lg font-semibold italic tracking-[-0.02em] text-ink-950"
      >
        "{setup.roast}"
      </blockquote>
      <div class="mt-5 flex flex-wrap gap-2">
        {
          setup.highlights.map((item) => (
            <span class="tag tag-accent">{item}</span>
          ))
        }
      </div>
    </div>
  </div>
</article>
