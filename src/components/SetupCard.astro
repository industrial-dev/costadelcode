---
import type { SetupCard } from '../data/site-content';
import { withBasePath } from '../utils/paths';

interface Props {
  setup: SetupCard;
}

const { setup } = Astro.props;
---

<article class="card overflow-hidden">
  <div class="bg-[rgb(255_255_255/0.7)] p-4 sm:p-6">
    <figure>
      <div
        class="overflow-hidden rounded-2xl border border-[rgb(17_17_17/0.08)] bg-white"
      >
        <img
          src={withBasePath(setup.imageSrc)}
          alt={setup.imageAlt}
          class="w-full"
          loading="lazy"
        />
      </div>
    </figure>
    <div class="mt-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-stone-500">
            {setup.name}
          </p>
          <h3
            class="mt-2 font-display text-xl font-semibold tracking-[-0.03em] text-ink-950 sm:text-2xl"
          >
            {setup.title}
          </h3>
        </div>
        <span class="tag">{setup.role}</span>
      </div>
      <blockquote
        class="mt-4 font-display text-base font-semibold italic tracking-[-0.02em] text-ink-950 sm:text-lg"
      >
        "{setup.roast}"
      </blockquote>
    </div>
  </div>
</article>
