---
import { withBasePath } from '../utils/paths';
import type { CommunityPage } from '../data/site-content';

interface Props {
  origin: NonNullable<CommunityPage['origin']>;
}

const { origin } = Astro.props;
---

<section class="section section-border bg-ink-950">
  <div class="shell mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16">
      <!-- Text content -->
      <div>
        <p class="eyebrow text-cream-200/60">{origin.eyebrow}</p>
        <h2 class="title-lg mt-4 text-cream-50">{origin.title}</h2>
        <p class="body-copy mt-5 text-cream-200/80">{origin.description}</p>
        <blockquote class="mt-10 border-l-2 border-code-green pl-6">
          <p
            class="font-display text-2xl font-semibold leading-snug tracking-[-0.04em] text-code-green"
          >
            "{origin.founderNote}"
          </p>
        </blockquote>
      </div>

      <!-- Pixel art portrait -->
      <div class="flex justify-center md:justify-end">
        <div class="relative">
          <!-- Glow backdrop -->
          <div
            class="pointer-events-none absolute -inset-4 rounded-sm bg-code-green/5 blur-2xl"
          >
          </div>
          <!-- Corner accents -->
          <div
            class="absolute -left-2 -top-2 h-5 w-5 border-l-2 border-t-2 border-code-green/60"
          >
          </div>
          <div
            class="absolute -bottom-2 -right-2 h-5 w-5 border-b-2 border-r-2 border-code-green/60"
          >
          </div>
          <img
            src={withBasePath('/images/photos/pixel_art_dani.webp')}
            alt="Dani, fundador de Costa del Code — pixel art"
            class="relative w-64 rounded-sm object-cover [image-rendering:pixelated] sm:w-72"
            loading="lazy"
          />
          <!-- Label below image -->
          <p
            class="mt-3 text-center font-mono text-xs tracking-widest text-cream-200/40 uppercase"
          >
            Dani · Fundador
          </p>
          {
            origin.founderPortfolio && (
              <div class="mt-4 flex justify-center">
                <a
                  href={origin.founderPortfolio}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-cream-200/20 px-5 py-2.5 font-sans text-sm font-semibold text-cream-200/70 transition-colors hover:border-cream-200/40 hover:text-cream-50"
                >
                  Ver portfolio
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 14 14"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M2 7h10M7 2l5 5-5 5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
