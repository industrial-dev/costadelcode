---
import type { FaqItem } from '../data/site-content';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<ul class="flex flex-col gap-3">
  {
    items.map((item) => (
      <li class="card border-l-[3px] border-l-accent-500 p-5 space-y-2">
        <p class="font-display text-lg font-semibold tracking-[-0.03em] text-ink-950">
          {item.question}
        </p>
        <p class="body-copy">{item.answer}</p>
      </li>
    ))
  }
</ul>
